{
  "name": "@jameymcelveen/cobble",
  "version": "0.2.0",
  "description": "Declarative filesystem DSL + plan/apply CLI — safe, exec-free, convergent idempotency",
  "type": "module",
  "bin": {
    "cobble": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "prepublishOnly": "npm run build",
    "plan": "node dist/cli.js plan",
    "apply": "node dist/cli.js apply"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jameymcelveen/homer.git"
  },
  "keywords": [
    "cobble",
    "declarative",
    "filesystem",
    "plan",
    "apply",
    "terraform",
    "dotfiles"
  ],
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
