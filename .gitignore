# --- Secrets: never commit (the one rule that matters most) ---
.env
.env.*
!.env.example
*.key
*.pem
*.pfx
secrets.*
**/appsettings.*.local.json

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# Editor — ignore local state; allow shared team configs
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json

.idea/*
!.idea/codeStyles/
!.idea/inspectionProfiles/
!.idea/runConfigurations/
!.idea/scopes/

*.swp
*~

# --- Logs / scratch ---
*.log
/tmp/
/scratch/
