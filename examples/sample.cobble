[COBBLE v=1]

[ROOT]
path=%CWD%/examples/sandbox

[ENSURE-DIR]
path=src

[WRITE-FILE]
name=src/hello.txt
<%
<!--cobble:start greeting-->
Hello from Cobble
<!--cobble:end-->
%>

[REPLACE]
name=src/hello.txt
marker=greeting
<%
Hello, World!
%>

[APPEND]
name=src/hello.txt
id=footer
<%
--- managed by cobble
%>
